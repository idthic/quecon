function quecon/jobdir-eval {
  if [[ ! $1 || ${1//[0-9]} ]]; then
    quecon/print "quecon: invalid job_index '$1'." >&2
    return 1
  fi

  local index=$((10#$1)) command=$2
  local jobdir i=0
  for jobdir in "$quecon_data_path"/jobs/????????-??????-*; do
    [[ -d $jobdir ]] || continue
    if ((++i==index)); then
      (cd "$jobdir"; eval -- "$command")
      return
    fi
  done
  quecon/print "quecon: job_index '$1' not found." >&2
  return 1
}

## @param[in] jobdir flags
## @var[out] line stat
function quecon/get-job-info {
  local jobdir=$1 flags=$2
  [[ -d $jobdir ]] || return 1
  line= stat=-
  ((index++))
  local job_id=${jobdir##*/}
  local fail=0 done=0 ntask=1
  local command=- cwd=- node=- time_start= time_end= system=

  # Note: "$jobdir"/stat?*.sh are the count files in the older directory
  # structure (before 2026-03-12).  We may remove the support after a while.
  local stat_sh
  for stat_sh in "$jobdir"/stat.sh "$jobdir"/stat?*.sh; do
    [[ -s $stat_sh ]] || continue
    source "$stat_sh"
  done
  if
    count_files=("$jobdir"/node?*/count.txt)
    ((${#count_files[@]}))
  then
    builtin eval -- "$(
      awk '
        /fail/ { fail++; }
        /done/ { done++; }
        END { printf("((fail += %d, done += %d))\n", fail, done); }
      ' "${count_files[@]}"
    )"
  fi

  [[ $stat == - && -s $jobdir/complete.mark ]] && stat=C

  local sgr_stat=
  if ((fail)); then
    [[ $stat == C* ]] && stat=F$fail
    [[ $stat == R ]] &&
      stat=R$done'!'$fail/$ntask
    sgr_stat=$'\e[1;91m'
  else
    case $stat in
    (K*) sgr_stat=$'\e[90m' ;;
    (F*) sgr_stat=$'\e[1;91m' ;;
    (C*) [[ $stat == C ]] && stat=COMP
         sgr_stat=$'\e[94m' ;;
    (R*) [[ $stat == R ]] &&
           stat=R$done/$ntask
         sgr_stat=$'\e[1;92m' ;;
    (P*) [[ $stat == P ]] && stat=PEND
         sgr_stat=$'\e[32m' ;;
    esac
  fi

  local time=-
  if [[ $time_start ]]; then
    [[ $time_end ]] || time_end=$(date +%s)
    local ret; quecon/string#seconds-to-human $((time_end-time_start)); time=$ret
  fi

  printf -v line \
         '%04d %-18s %-10.10s %s%-6s%s %-6s %s' \
         "$index" "$job_id" "$node" \
         "$sgr_stat" "$stat" $'\e[m' \
         "$time" "$command"
}

#-----------------------------------------------------------------------------
# submit

## @fn cmd:submit/make-jobdir
##   @var[out] jobdir
function cmd:submit/make-jobdir {
  jobdir=
  local jobdir_base=$quecon_data_path/jobs
  [[ -d $jobdir_base ]] || mkdir -p "$jobdir_base"
  local date=$(date +%Y%m%d-%H%M%S)
  local index=0
  for ((index=0;index<100;index++)); do
    printf -v jobdir %s/%s-%02d "$jobdir_base" "$date" "$index"
    mkdir "$jobdir" 2>/dev/null && return 0
  done
  jobdir=
  quecon/print "quecon: failed to create job directory" >&2
  return 1
}

## @fn cmd:submit/save-binary src lnk
##   指定した名前の実行ファイルを PATH から探索して、
##   DATA_PATH/jobs/bin に hash 値と共にコピーします。
##   更に其処への相対パスでのシンボリックリンクを lnk に作成します。
##   lnk は DATA_PATH/jobs/XXX/bin/YYY の形式であると想定します。
function cmd:submit/save-binary {
  local src=$1 dst=$2
  local bin_path
  if ! bin_path=$(type -p "$src"); then
    "quecon: failed to find the binary '$src'." >&2
    return 1
  fi

  if type -p sha256sum &>/dev/null; then
    bin_hash=$(sha256sum "$bin_path" | awk '{print $1}')
  elif type -p md5sum &>/dev/null; then
    bin_hash=$(md5sum "$bin_path" | awk '{print $1}')
  fi

  local cache=$quecon_data_path/jobs/bin/${src##*/}.$bin_hash
  if [[ ! -f $cache ]]; then
    mkpd "$cache"
    cp -L "$bin_path" "$cache"
  fi
  mkpd "$dst"
  ln -s "../../bin/${cache##*/}" "$dst"
}

## @fn cmd:submit/readargs args...
##   @var[out] flags
##     c   copy executable
##     t   create QUECON_TMPDIR
##     r   set range
##     E   error
##   @var[out] command
##   @var[out] range_{rep,beg,end,node,work.core}
##   @var[out] job_name
##   @var[out] bin_names
##   @var[out] job_system
quecon/readargs/define-flag-option   submit c:copy          c
quecon/readargs/define-flag-option   submit t:create-tmpdir t
quecon/readargs/define-array-option  submit C:copy-binary   bin_names
quecon/readargs/define-scalar-option submit J:job-name      job_name
quecon/readargs/define-scalar-option submit system          job_system
function quecon/readargs:submit/option:r {
  quecon/readargs/get-optarg && range=$optarg flags=r$flags
}
quecon/readargs/define-longname submit r repeat
function quecon/readargs:submit/process-argument {
  if [[ ! $command ]]; then
    command=$arg
  else
    quecon/readargs/argerr "redundant argument '$arg'."
  fi
}
function cmd:submit/readargs {
  flags=
  command= job_name= job_system=$quecon_system
  bin_names=()
  local range

  quecon/readargs submit "$@"

  if [[ ! $command ]]; then
    quecon/print "quecon: command is not specified." >&2
    flags+=E
  fi

  # parse range
  range_rep=
  range_beg=0
  range_end=1
  range_node=1
  range_work=1
  range_core=1
  if [[ $range ]]; then
    local rex='([^=]+=)?([0-9]+:)?([0-9]+)(/[0-9]+(x[0-9]+(x[0-9]+)?)?)?'
    if ! [[ $range =~ $rex ]]; then
      quecon/print "quecon: invalid range spec '-r $range'." >&2
      flags+=E
    fi
    range_rep=${BASH_REMATCH[1]%=}
    range_beg=${BASH_REMATCH[2]%:}
    range_end=${BASH_REMATCH[3]}
    range_node=${BASH_REMATCH[4]#/}
    range_node=${range_node%%x*}
    range_work=${BASH_REMATCH[5]#x}
    range_work=${range_work%%x*}
    range_core=${BASH_REMATCH[6]#x}
    [[ $range_beg ]] || range_beg=0
    [[ $range_node ]] || range_node=1
    [[ $range_work ]] || range_work=1
    [[ $range_core ]] || range_core=1
  fi

  [[ $flags != *E* ]]
}

## @fn cmd:submit/.submit-rjob
##   @var[in] flags
##   @var[in] command
##   @var[in] job_name
##   @var[in] bin_names
##   @var[in] job_system
##   @var[in] submit_hash
##   @var[in] range_rep
##   @var[in] rjob_beg
##   @var[in] rjob_end
##   @var[in] rjob_step
##   @var[in] rjob_node
##   @var[in] rjob_work
##   @var[in] rjob_core
function cmd:submit/.submit-rjob {
  local q=\' Q="'\''"

  local rjob_ntask=$(((rjob_end-rjob_beg+rjob_step-1)/rjob_step))
  ((rjob_ntask>0)) || break

  local jobdir
  cmd:submit/make-jobdir || return 1

  # Copy executable
  local command1=$command
  if [[ $flags == *c* ]]; then
    local cmd=${command%%[$IFS]*}
    local fcmd=$jobdir/cmd.sh
    if [[ -x $cmd ]] && cp -L "$cmd" "$fcmd"; then
      command1=$fcmd${command:${#cmd}}
    else
      "quecon: failed to copy the file '$cmd'." >&2
      return 1
    fi
  fi
  local bin_name ret
  for bin_name in "${bin_names[@]}"; do
    cmd:submit/save-binary "$bin_name" "$jobdir/bin/${bin_name##*/}" || return 1
  done

  # repeat の説明
  local job_range_suffix=
  local cmd_range_suffix=
  local log_range_suffix=
  if [[ $flags == *r* ]]; then
    local repeat_text
    if ((rjob_ntask==1)); then
      repeat_text=$rjob_beg
    elif ((rjob_step==1)); then
      local rjob_max=$((rjob_beg+(rjob_ntask-1)))
      repeat_text={$rjob_beg..$rjob_max}
    else
      local rjob_max=$((rjob_beg+(rjob_ntask-1)*rjob_step))
      repeat_text={$rjob_beg..$rjob_max..$rjob_step}
    fi
    log_range_suffix=" repeat=$repeat_text"
    job_range_suffix="$repeat_text"
    cmd_range_suffix=" (${range_rep:+$range_rep=}$repeat_text)"
  fi
  local job_title=$job_name${job_range_suffix:+/$job_range_suffix}

  local fsub=$jobdir/sub.sh
  local flog=$jobdir/stat.log
  local fstat=$jobdir/stat.sh
  {
    local _quecon_tmpdir=
    [[ $flags == *t* ]] && _quecon_tmpdir=$quecon_tmpdir_base/${jobdir##*/}

    quecon/print '#!/usr/bin/env bash'
    quecon/system:"$job_system"/emit-submit-header -D "$jobdir" -N "$rjob_node" -n "$rjob_work" -c "$rjob_core" -J "$job_title" "$fsub"
    quecon/print "QUECON_JOBDIR='${jobdir//$q/$Q}'"
    quecon/print "QUECON_TMPDIR='${_quecon_tmpdir//$q/$Q}'"
    quecon/print "QUECON_NNODE='${rjob_node//$q/$Q}'"
    sed -n '/__QUECON_END_PARAMS__/,$p' "$quecon_data_path"/template/sub.sh
  } > "$fsub"

  local inode
  for ((inode=0;inode<rjob_node;inode++)); do
    local node_beg=$((rjob_beg+inode*rjob_step))
    local node_end=$rjob_end
    local node_step=$((rjob_step*rjob_node))
    local node_work=$rjob_work
    local node_core=$rjob_core

    local fnode
    printf -v fnode '%s/node%03d.sh' "$jobdir" "$inode"
    local nodedir=${fnode%.sh}
    mkd "$nodedir"
    {
      quecon/print '#!/usr/bin/env bash'
      quecon/system:"$job_system"/emit-node-header
      quecon/print "QUECON_JOBDIR='${jobdir//$q/$Q}'"
      quecon/print "QUECON_TMPDIR='${_quecon_tmpdir//$q/$Q}'"
      quecon/print "QUECON_NODE='${inode//$q/$Q}'"
      quecon/print "QUECON_NODEDIR='${nodedir//$q/$Q}'"
      sed -n '/__QUECON_END_PARAMS__/,$p' "$quecon_data_path"/template/node.sh
    } > "$fnode"

    : > "$nodedir/stat.sh"

    local iwork
    for ((iwork=0;iwork<node_work;iwork++)); do
      local work_beg=$((node_beg+iwork*node_step))
      local work_end=$node_end
      local work_step=$((node_step*node_work))
      ((work_beg<work_end)) || break

      local fwork
      printf -v fwork '%s/work%03d.sh' "$nodedir" "$iwork"
      {
        quecon/print '#!/usr/bin/env bash'
        quecon/print "QUECON_JOBDIR='${jobdir//$q/$Q}'"
        quecon/print "QUECON_NODEDIR='${nodedir//$q/$Q}'"
        quecon/print "QUECON_COMMAND='${command1//$q/$Q}'"
        quecon/print "QUECON_INODE='${inode//$q/$Q}'"
        quecon/print "QUECON_IWORK='${iwork//$q/$Q}'"
        quecon/print "QUECON_REPBEG='${work_beg//$q/$Q}'"
        quecon/print "QUECON_REPEND='${work_end//$q/$Q}'"
        quecon/print "QUECON_REPSTEP='${work_step//$q/$Q}'"
        quecon/print "QUECON_REPLACE='${range_rep//$q/$Q}'"
        quecon/print "QUECON_PWD='${PWD//$q/$Q}'"
        quecon/print "QUECON_HOME='${HOME//$q/$Q}'"
        sed -n '/__QUECON_END_PARAMS__/,$p' "$quecon_data_path"/template/work.sh
      } > "$fwork"
    done
    chmod +x "$nodedir"/work[0-9]*.sh
  done
  chmod +x "$jobdir"/node[0-9]*.sh

  local date=$(date +"%F %T %Z")
  quecon/print "submit: $command$cmd_range_suffix"
  quecon/print "[$date] $submit_hash JOB_ID ${jobdir##*/}$log_range_suffix" >> "$quecon_data_path"/submit.log
  quecon/print "[$date] QUECON submit" >> "$flog"
  {
    quecon/print "command='${command//$q/$Q}$cmd_range_suffix'"
    quecon/print "cwd='${PWD//$q/$Q}'"
    quecon/print "ntask=$rjob_ntask"
    quecon/print "stat=P"
  } >> "$fstat"

  if ! quecon/system:"$job_system"/submit -D "$jobdir" -N "$rjob_node" -n "$rjob_work" -c "$rjob_core" -J "$job_title" "$fsub"; then
    quecon/print "quecon:${jobdir##*/}: failed to submit" >&2
    quecon/print "[$(date +"%F %T %Z")] QUECON submit fail" >> "$flog"
    quecon/print "stat=F" >> "$fstat"
    return 1
  fi
}

function cmd:submit {
  local q=\' Q="'\''"

  local flags command job_name bin_names job_system
  local range_{rep=,beg=0,end=1,step=1,node=1,work=1}
  cmd:submit/readargs "$@" || return 2

  local submit_hash
  printf -v submit_hash '#%04X' "$RANDOM"
  local date=$(date +"%F %T %Z")
  local ret; quote-words quecon submit "$@"
  quecon/print "[$date] $submit_hash $ret" >> "$quecon_data_path"/submit.log
  quecon/print "[$date] $submit_hash PWD='${PWD//$q/$Q}'" >> "$quecon_data_path"/submit.log

  # Job name
  [[ $job_name ]] || job_name=$command

  if quecon/system:"$job_system"/supports-multinode; then
    local rjob_beg=$range_beg
    local rjob_end=$range_end
    local rjob_step=$range_step
    local rjob_node=$range_node
    local rjob_work=$range_work
    local rjob_core=$range_core
    cmd:submit/.submit-rjob
  else
    local irjob
    for ((irjob=0;irjob<range_node;irjob++)); do
      local rjob_beg=$((range_beg+irjob*range_step))
      local rjob_end=$range_end
      local rjob_step=$((range_step*range_node))
      local rjob_node=1
      local rjob_work=$range_work
      local rjob_core=$range_core
      cmd:submit/.submit-rjob
    done
  fi
}

quecon/readargs/define-flag-option stat a:all        a
quecon/readargs/define-flag-option stat A:all-record A
quecon/readargs/define-flag-option stat help         H
quecon/readargs/define-flag-option stat version      V
function quecon/readargs:stat/process-argument {
  if [[ ! $id ]]; then
    if [[ ! $arg || ${arg//[0-9]} ]]; then
      quecon/print "quecon: invalid job id '$arg'." >&2
      flags=E$flags
    else
      id=$arg
    fi
  elif [[ ! $type ]]; then
    if [[ ! $arg ]]; then
      quecon/print "quecon: invalid argument ''." >&2
      flags=E$flags
    else
      type=$arg
    fi
  else
    quecon/readargs/argerr "quecon: redundant argument '$arg'"
    return 1
  fi
}

## @fn cmd:stat/list
##   @var[in] flags
function cmd:stat/list {
  quecon/print 'INDE JOB_ID             NODE       STAT   TIME   COMMAND'
  if [[ $flags == *A* ]]; then
    local -a stat_files=()
    local stat_file
    for stat_file in "$quecon_data_path"/jobs/[2-9]???????.stat; do
      stat_files+=("$stat_file")
      local i=1 stat_file_sub
      while
        stat_file_sub=${stat_file%.stat}-$i.stat
        [[ -f $stat_file_sub ]]
      do
        stat_files+=("$stat_file_sub")
        ((i++))
      done
    done
    ((${#stat_files[@]})) && cat "${stat_files[@]}"
  fi

  local jobdir index=0
  for jobdir in "$quecon_data_path"/jobs/????????-??????-*; do
    local line stat
    quecon/get-job-info "$jobdir" || continue
    [[ $flags != *a* && $stat == [CK]* ]] && continue
    printf '%s\n' "$line"
  done
}

function cmd:stat/print-version {
  printf 'quecon (idt) 1.0.0\n'
}
