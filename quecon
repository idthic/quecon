}
function cmd:stat {
  local flags= id= type=
  quecon/readargs stat "$@" || return 2

  [[ $flags == *V* ]] &&
    cmd:stat/print-version
  [[ $flags == *H* ]] &&
    cmd:stat/print-help
  [[ $flags == *[HV]* ]] && return 0

  if [[ ! $id ]]; then
    cmd:stat/list
    return "$?"
  fi

  case $type in
  (path)
    quecon/jobdir-eval "$id" 'quecon/print $PWD' ;;
  (''|log)
    quecon/jobdir-eval "$id" 'cat stat.log' ;;
  (out|tail)
    local -a tail_options=()
    tail_options=()
    if [[ $2 == out ]]; then
      tail_options+=(-n +1)
    else
      tail_options+=(-n 10)
    fi
    quecon/jobdir-eval "$id" '
      [[ ! -s complete.mark && -t 1 ]] && tail_options+=(-f)
      tail "${tail_options[@]}" sub.out' ;;
  (cmd.sh|sub.sh|node[0-9]*.sh|node[0-9]*/work[0-9]*.sh)
    quecon/jobdir-eval "$id" "cat $type" ;;
  (stat.log|stat.sh|sub.out|sub.e|sub.o|complete.mark)
    quecon/jobdir-eval "$id" "cat $type" ;;
  (node[0-9]*/count.txt|node[0-9]*/stat.out|node[0-9]*/stat.log|node[0-9]*/stat.sh|node[0-9]*/complete.mark)
    quecon/jobdir-eval "$id" "cat $type" ;;
  (stat*.sh|job*.sh)
    quecon/jobdir-eval "$id" "cat $type" ;;
  (ls)
    local prefix=
    if type -P colored &>/dev/null; then
      prefix='colored '
    fi
    quecon/jobdir-eval "$id" "${prefix}ls -la" ;;
  (node[0-9]*[0-9])
    local prefix=
    if type -P colored &>/dev/null; then
      prefix='colored '
    fi
    quecon/jobdir-eval "$id" "${prefix}ls -la $type" ;;
  (*)
    quecon/print "quecon/stat: unknown stat type '$type'" >&2
    return 2 ;;
  esac
}

function cmd:archive {
  # determine date
  local jdir=$quecon_data_path/jobs
  local date=$(date +'%Y%m%d') index=0
  while [[ -s $jdir/$date.stat ]]; do
    date=${date%-*}-$((++index))
  done

  local archive=$jdir/$date-archive.tar.xz
  local tmpdir=$jdir/$date-archive
  local statfile=$jdir/$date.stat
  mkd "$tmpdir"

  local jobdir index=0
  for jobdir in "$jdir"/2???????-??????-??; do
    local line stat
    quecon/get-job-info "$jobdir" || continue
    [[ $stat == [CFK]* ]] || continue
    printf '%s\n' "$line" >> "$statfile"
    mv "$jobdir" "$tmpdir"
  done
  if [[ -s $statfile ]]; then
    (cd "$jdir"; tar cavf "${archive##*/}" "${tmpdir##*/}") &&
      mkd "$jdir/gomi" &&
      mv "$tmpdir" "$jdir/gomi/"
  else
    rmdir "$tmpdir"
  fi
}

## @option -f ... Remove the entry even if the kill command fails.
quecon/readargs/define-flag-option kill f:force f
function quecon/readargs:kill/process-argument {
  if [[ $job ]]; then
    quecon/readargs/argerr "redundant argument '$arg'." >&2
    return 1
  fi
  if [[ ! $arg ]]; then
    quecon/readargs/argerr "invalid argument '$arg'." >&2
    return 1
  fi
  job=$arg
}
## @fn quecon/kill.readargs [-f] SCRIPT
##   @var[out] flags job
function quecon/kill.readargs {
  flags= job=
  quecon/readargs kill "$@"
  if [[ ! $job ]]; then
    quecon/print "quecon kill: <job> is not specified." >&2
    flags=E$flags
  fi
  [[ $flags != *E* ]]
}
function cmd:kill/proc {
  [[ -s stat.sh ]] || return 1
  local command=- cwd=- node=- time_start= time_end= system=
  source stat.sh
  [[ $stat == - && -s $jobdir/complete.mark ]] && stat=C

  # already completed
  [[ $stat == C || $stat == F ]] && return 1

  if [[ ! $system ]]; then
    quecon/print "${PWD##*/}: failed to kill the job with an unknown type." >&2
    return 1
  fi

  local job_system=${system%%:*}
  if quecon/system:"$job_system"/kill "${system}" || [[ $kill_flags == *f* ]]; then
    {
      quecon/print "stat=K"
      date +'time_end=%s'
    } >> stat.sh
    return 0
  else
    quecon/print "quecon ($job_system): failed to kill JOB ${PWD##*/}" >&2
    return 1
  fi
}
function cmd:kill {
  local flags job
  quecon/kill.readargs "$@" || return 2
  local kill_flags=$flags
  quecon/jobdir-eval "$job" 'cmd:kill/proc'
}

