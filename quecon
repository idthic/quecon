function main {
  if (($#==0)) || [[ $1 == -* ]]; then
    cmd:stat "$@"
    return
  elif quecon/is-function "cmd:$1"; then
    "cmd:$@"
    return
  elif local rex='^[0-9]+$'; [[ $1 =~ $rex ]]; then
    cmd:stat "$1" "${@:2}"
    return
  fi

  # case $1 in
  # (*)
  # esac

  quecon/print "quecon: unknown subcommand '$1'" >&2
  exit 2
}

main "$@"
